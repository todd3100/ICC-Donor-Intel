# Postgres connection string (Railway auto-injects this when you attach the Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/icc_donor_intel

# Random 64+ character secret. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string

# Anthropic API key for the Claude research engine
ANTHROPIC_API_KEY=sk-ant-...

# Seed admin (used once on first boot to create the initial admin account)
SEED_ADMIN_EMAIL=admin@israelcc.org
SEED_ADMIN_PASSWORD=change-me-on-first-login

# Server port (Railway injects PORT automatically; 3000 is the local default)
PORT=3000

# Optional: set to "production" on Railway; leave unset locally
NODE_ENV=development
